# Copy to .env and fill in what you need:  cp .env.example .env

# ─── Auth ───
# Set a password to require login. Leave empty to run open (no auth).
AUTH_PASSWORD=

# ─── Email (SMTP) notifications ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_ADDRESS=

# ─── Other notification channels (optional) ───
SLACK_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK=
WEBHOOK_URL=
